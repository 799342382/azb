{
  "name": "ai-toolbox-desktop",
  "version": "1.0.2",
  "main": "main.js",
  "private": true,
  "scripts": {
    "dev": "electron .",
    "dist": "electron-builder --win --x64 --publish never"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.guojin.aitoolbox",
    "productName": "AI工具箱",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "AI工具箱-安装包-${version}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": null
  }
}
